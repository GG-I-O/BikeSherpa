{
  "AllowedHosts": "*",
  "CORS": {
    "AllowedOrigins": "https://localhost,https://dev.bike.local"
  },
  "Serilog": {
    "WriteTo": [
      {
        "Name": "GrafanaLoki",
        "Args": {
          "uri": "https://loki.localhost.com",
          "PropertiesAsLabels": ["service_name", "env", "app", "machine"]
        }
      },
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} level=[{Level:u3}] app={app} machine={machine} env={env} {Message:lj} {NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/applog.txt",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} level=[{Level:u3}] app={app} machine={machine} env={env} {Message:lj} {NewLine}{Exception}",
          "fileSizeLimitBytes": 104857600,
          "rollOnFileSizeLimit": true,
          "retainedFileCountLimit": 5
        }
      }
    ]
  }
}